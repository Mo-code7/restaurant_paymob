<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════
         Form View - Restaurant order
    ═══════════════════════════════════════════════════ -->
    <record id="restaurant_order_view_form" model="ir.ui.view">
        <field name="name">restaurant.order.form</field>
        <field name="model">restaurant.order</field>
        <field name="arch" type="xml">
            <form string="Restaurant order">

                <!-- Status Bar -->
                <header>
                    <button name="action_confirm"
                            string="Confirm Order"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_start_preparing"
                            string="Start Preparing"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'confirmed'"/>

                    <button name="action_ready"
                            string="Ready"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'preparing'"/>

                    <button name="action_pay_with_paymob"
                            string="Pay with PayMob 💳"
                            type="object"
                            class="btn-success"
                            invisible="state not in ('confirmed', 'preparing', 'ready') or payment_status == 'success'"/>

                    <button name="action_open_payment_url"
                            string="Open the payment link 🔗"
                            type="object"
                            class="btn-info"
                            invisible="not paymob_payment_url or payment_status == 'success'"/>

                    <button name="action_mark_paid"
                            string="Manual payment ✅"
                            type="object"
                            invisible="state not in ('confirmed', 'preparing', 'ready')"/>

                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-danger"
                            invisible="state in ('paid', 'done', 'cancel')"/>

                    <button name="action_reset_draft"
                            string="Set to Draft"
                            type="object"
                            invisible="state != 'cancel'"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,preparing,ready,paid,done"/>
                </header>

                <sheet>
                    <!-- PayMob Payment Status Banner -->
                    <div class="alert alert-success"
                         invisible="payment_status != 'success'">
                        <strong>Payment successfully! ✅</strong>
                        Transaction ID: <field name="paymob_transaction_id" readonly="1"/>
                    </div>
                    <div class="alert alert-danger"
                         invisible="payment_status != 'failed'">
                        <strong>Payment failed ❌</strong> Please try again.
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Order data">
                            <field name="partner_id"/>
                            <field name="order_type"/>
                            <field name="table_number"
                                   invisible="order_type != 'dine_in'"/>
                        </group>
                        <group string="Pay data">
                            <field name="currency_id" invisible="1"/>
                            <field name="payment_status" readonly="1"/>
                            <field name="paymob_order_id" readonly="1"
                                   invisible="not paymob_order_id"/>
                            <field name="paymob_payment_url" readonly="1" widget="url"
                                   invisible="not paymob_payment_url"/>
                        </group>
                    </group>

                    <!-- Order category -->
                    <notebook>
                        <page string="Categories 🍽️" name="order_lines">
                            <field name="order_line_ids" invisible="state in ('paid', 'done')">
                                <list editable="bottom">
                                    <!-- <column_invisible>parent.state in ('paid', 'done')</column_invisible> -->
                                    <field name="product_id"/>
                                    <field name="product_qty"/>
                                    <field name="price_unit"/>
                                    <field name="tax_ids" widget="many2many_tags"/>
                                    <field name="price_subtotal" readonly="1"/>
                                    <field name="notes" optional="show"/>
                                </list>
                            </field>

                            <!-- Totals -->
                            <group class="oe_subtotal_footer">
                                <field name="amount_untaxed" readonly="1"/>
                                <field name="amount_tax" readonly="1"/>
                                <field name="amount_total" readonly="1"
                                       class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>

                        <page string="Notes 📝" name="notes">
                            <field name="notes" placeholder="Any notes regarding the order..."/>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════
         List View
    ═══════════════════════════════════════════════════ -->
    <record id="restaurant_order_view_list" model="ir.ui.view">
        <field name="name">restaurant.order.list</field>
        <field name="model">restaurant.order</field>
        <field name="arch" type="xml">
            <list string="Restaurant Orders" decoration-success="state == 'paid'"
                  decoration-warning="state == 'preparing'"
                  decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="order_type"/>
                <field name="table_number" optional="show"/>
                <field name="amount_total"/>
                <field name="payment_status" widget="badge"
                       decoration-success="payment_status == 'success'"
                       decoration-danger="payment_status == 'failed'"
                       decoration-warning="payment_status == 'pending'"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'paid'"
                       decoration-primary="state == 'preparing'"
                       decoration-muted="state == 'cancel'"/>
                <field name="create_date" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════
         Kanban View
    ═══════════════════════════════════════════════════ -->
    <record id="restaurant_order_view_kanban" model="ir.ui.view">
        <field name="name">restaurant.order.kanban</field>
        <field name="model">restaurant.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="amount_total"/>
                <field name="state"/>
                <field name="payment_status"/>
                <field name="order_type"/>
                <templates>
                    <t t-name="kanban-card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <strong>
                                        <field name="name"/>
                                    </strong>
                                    <span class="badge"
                                          t-attf-class="badge #{record.payment_status.raw_value == 'success' ? 'text-bg-success' : 'text-bg-secondary'}">
                                        <field name="payment_status"/>
                                    </span>
                                </div>
                                <div>
                                    <field name="partner_id"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <strong>
                                        <field name="amount_total"/>
                                        <field name="currency_id" invisible="1"/>
                                    </strong>
                                    <field name="order_type"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════
         Search View
    ═══════════════════════════════════════════════════ -->
    <record id="restaurant_order_view_search" model="ir.ui.view">
        <field name="name">restaurant.order.search</field>
        <field name="model">restaurant.order</field>
        <field name="arch" type="xml">
            <search string="Search in order">
                <field name="name" string="Order NO."/>
                <field name="partner_id" string="Customer"/>
                <separator/>
                <filter string="Draft"           name="draft"     domain="[('state','=','draft')]"/>
                <filter string="preparing"    name="preparing" domain="[('state','=','preparing')]"/>
                <filter string="Ready"           name="ready"     domain="[('state','=','ready')]"/>
                <filter string="PAid"          name="paid"      domain="[('state','=','paid')]"/>
                <separator/>
                <filter string="Success"       name="paid_ok"   domain="[('payment_status','=','success')]"/>
                <filter string="Failed"       name="paid_fail" domain="[('payment_status','=','failed')]"/>
                <separator/>
                <filter string="Today"          name="today"
                        domain="[('create_date','&gt;=', (context_today()).strftime('%Y-%m-%d'))]"/>
                <group>
                    <filter string="status"     name="group_state"   context="{'group_by': 'state'}"/>
                    <filter string="Order type"  name="group_type"    context="{'group_by': 'order_type'}"/>
                    <filter string="Customer"     name="group_partner" context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════
         Action
    ═══════════════════════════════════════════════════ -->
    <record id="restaurant_order_action" model="ir.actions.act_window">
        <field name="name">Restaurant Orders</field>
        <field name="res_model">restaurant.order</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="restaurant_order_view_search"/>
        <field name="context">{'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first order for the restaurant!
            </p>
            <p>
                Place orders and pay electronically via PayMob with ease. 
            </p>
        </field>
    </record>

</odoo>
