<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_paymob" model="ir.ui.view">
        <field name="name">res.config.settings.paymob</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='general_settings']" position="inside">
                <div class="app_settings_block" data-string="PayMob for the restaurant" string="PayMob for the restaurant">
                    <h2>PayMob settings</h2>
                    <div class="text-muted mb-3">
                        Get this data from the PayMob dashboard:
                        <a href="https://accept.paymob.com" target="_blank">accept.paymob.com</a>
                    </div>
                    <div class="row mt16 o_settings_container">
                        <div class="col-xs-12 col-md-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="paymob_api_key" string="API Key"/>
                                <div class="text-muted">
                                    from: Settings > Account Info > API Key
                                </div>
                                <div class="content-group">
                                    <field name="paymob_api_key" password="True"
                                           placeholder="ZXh0ZXJuYWwtZX..."/>
                                </div>
                            </div>
                        </div>
                        <div class="col-xs-12 col-md-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="paymob_integration_id" string="Integration ID"/>
                                <div class="text-muted">
                                    from: Settings > Integrations > Online Card
                                </div>
                                <div class="content-group">
                                    <field name="paymob_integration_id" placeholder="123456"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-xs-12 col-md-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="paymob_iframe_id" string="iFrame ID"/>
                                <div class="text-muted">
                                    from: Settings > iFrames
                                </div>
                                <div class="content-group">
                                    <field name="paymob_iframe_id" placeholder="99999"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-xs-12 col-md-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="paymob_hmac_secret" string="HMAC Secret"/>
                                <div class="text-muted">
                                To check the Webhook (optional but recommended)
                                </div>
                                <div class="content-group">
                                    <field name="paymob_hmac_secret" password="True"
                                           placeholder="your_hmac_secret"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="alert alert-info mt-2">
                        <strong>🔗 Webhook URL:</strong>
                        Set this link in PayMob under "Transaction Processed Callback":
                        <code>https://yourdomain.com/paymob/webhook</code>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
